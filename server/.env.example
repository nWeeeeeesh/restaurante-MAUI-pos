# ─── MauiDesk — Configuración del servidor ─────────────────────────────────────
# Copiar este archivo a `.env` y llenar los valores reales.
# `.env` está en .gitignore — nunca commitearlo.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Seguridad (OBLIGATORIO) ───────────────────────────────────────────────────
# JWT_SECRET: clave para firmar tokens de sesión. Mínimo 32 caracteres.
# El servidor aborta al arrancar si falta o es demasiado corto.
# Generar uno nuevo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiar_por_uno_generado_con_el_comando_de_arriba_minimo_32_chars

# ─── CORS allowlist ────────────────────────────────────────────────────────────
# Lista separada por comas de orígenes que pueden acceder al API y al WebSocket.
# - En desarrollo: dejar vacío → usa http://localhost:5173 y http://localhost:3001
# - En producción local (Raspberry): incluir el origen desde el que sirve el client
#   Ejemplo Pi: ALLOWED_ORIGINS=http://192.168.1.50:3001,http://mauidesk.local:3001
# - "*" abre a cualquier origen (solo si tenés redes LAN dinámicas; no recomendado)
ALLOWED_ORIGINS=

# ─── Base de datos (SQLite via libsql) ─────────────────────────────────────────
# En el Pi se recomienda ruta absoluta apuntando al SSD USB:
#   DATABASE_URL=file:/home/mauidesk/MAUI/server/mauidisk.db
DATABASE_URL=file:./mauidisk.db

# ─── Impresora térmica ─────────────────────────────────────────────────────────
# Tres modos soportados:
#
# 1) TCP (Ethernet/WiFi)  — recomendado para producción
#    PRINTER_TYPE=tcp
#    PRINTER_HOST=192.168.1.100   ← IP fija de la impresora
#    PRINTER_PORT=9100            ← puerto ESC/POS estándar
#
# 2) Windows (USB local) — solo para desarrollo en PC Windows
#    PRINTER_TYPE=windows
#    PRINTER_NAME="POS-D Basic 200"   ← nombre exacto del driver instalado
#
# 3) (Linux USB no implementado — usamos TCP en el Pi)

PRINTER_TYPE=tcp
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100
# PRINTER_NAME=
